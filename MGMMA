		[NinjaScriptProperty]
		[Range(1, int.MaxValue)]
		[Display(Name = "P5 period",  Order = 5,  GroupName = "Periods")]
		public int P5 { get; set; }

		[NinjaScriptProperty]
		[Range(1, int.MaxValue)]
		[Display(Name = "P6 period",  Order = 6,  GroupName = "Periods")]
		public int P6 { get; set; }

		[NinjaScriptProperty]
		[Range(1, int.MaxValue)]
		[Display(Name = "P7 period",  Order = 7,  GroupName = "Periods")]
		public int P7 { get; set; }

		[NinjaScriptProperty]
		[Range(1, int.MaxValue)]
		[Display(Name = "P8 period",  Order = 8,  GroupName = "Periods")]
		public int P8 { get; set; }

		[NinjaScriptProperty]
		[Range(1, int.MaxValue)]
		[Display(Name = "P9 period",  Order = 9,  GroupName = "Periods")]
		public int P9 { get; set; }

		[NinjaScriptProperty]
		[Range(1, int.MaxValue)]
		[Display(Name = "P10 period", Order = 10, GroupName = "Periods")]
		public int P10 { get; set; }

		[NinjaScriptProperty]
		[Range(1, int.MaxValue)]
		[Display(Name = "P11 period", Order = 11, GroupName = "Periods")]
		public int P11 { get; set; }

		[NinjaScriptProperty]
		[Range(1, int.MaxValue)]
		[Display(Name = "P12 period", Order = 12, GroupName = "Periods")]
		public int P12 { get; set; }

		// ----- Show/Hide toggles -----
		// Note: the period value shown in the label below is the DEFAULT —
		// it doesn't auto-update if the user changes Px, because NinjaTrader's
		// Display attribute is static. For the live value, the user can look
		// at the Periods group above.
		[NinjaScriptProperty]
		[Display(Name = "Show P1 (default 3)",   Order = 1,  GroupName = "Show / Hide")]
		public bool Show_P1 { get; set; }

		[NinjaScriptProperty]
		[Display(Name = "Show P2 (default 5)",   Order = 2,  GroupName = "Show / Hide")]
		public bool Show_P2 { get; set; }

		[NinjaScriptProperty]
		[Display(Name = "Show P3 (default 8)",   Order = 3,  GroupName = "Show / Hide")]
		public bool Show_P3 { get; set; }

		[NinjaScriptProperty]
		[Display(Name = "Show P4 (default 10)",  Order = 4,  GroupName = "Show / Hide")]
		public bool Show_P4 { get; set; }

		[NinjaScriptProperty]
		[Display(Name = "Show P5 (default 12)",  Order = 5,  GroupName = "Show / Hide")]
		public bool Show_P5 { get; set; }

		[NinjaScriptProperty]
		[Display(Name = "Show P6 (default 15)",  Order = 6,  GroupName = "Show / Hide")]
		public bool Show_P6 { get; set; }

		[NinjaScriptProperty]
		[Display(Name = "Show P7 (default 30)",  Order = 7,  GroupName = "Show / Hide")]
		public bool Show_P7 { get; set; }

		[NinjaScriptProperty]
		[Display(Name = "Show P8 (default 35)",  Order = 8,  GroupName = "Show / Hide")]
		public bool Show_P8 { get; set; }

		[NinjaScriptProperty]
		[Display(Name = "Show P9 (default 40)",  Order = 9,  GroupName = "Show / Hide")]
		public bool Show_P9 { get; set; }

		[NinjaScriptProperty]
		[Display(Name = "Show P10 (default 45)", Order = 10, GroupName = "Show / Hide")]
		public bool Show_P10 { get; set; }

		[NinjaScriptProperty]
		[Display(Name = "Show P11 (default 50)", Order = 11, GroupName = "Show / Hide")]
		public bool Show_P11 { get; set; }

		[NinjaScriptProperty]
		[Display(Name = "Show P12 (default 60)", Order = 12, GroupName = "Show / Hide")]
		public bool Show_P12 { get; set; }
		#endregion
	}
