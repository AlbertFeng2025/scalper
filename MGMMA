namespace NinjaTrader.NinjaScript.Indicators
{
	public class Michelle_GMMA : Indicator
	{
		protected override void OnStateChange()
		{
			if (State == State.SetDefaults)
			{
				Description					= @"Guppy Multiple Moving Average (GMMA) — 12 EMAs, user-toggleable.";
				Name						= "Michelle_GMMA";
				Calculate					= Calculate.OnBarClose;
				IsOverlay					= true;   // GMMA plots on the price panel
				DisplayInDataBox			= true;
				DrawOnPricePanel			= true;
				PaintPriceMarkers			= true;
				ScaleJustification			= NinjaTrader.Gui.Chart.ScaleJustification.Right;
				IsSuspendedWhileInactive	= true;

				// --- Colors (hex codes from the original formula) ---
				// Orange #FF8D1E for the short-term group (P1–P6)
				// Cyan   #13FFFF for the long-term  group (P7–P12)
				Brush orange = new SolidColorBrush(Color.FromRgb(0xFF, 0x8D, 0x1E));
				orange.Freeze();
				Brush cyan = new SolidColorBrush(Color.FromRgb(0x13, 0xFF, 0xFF));
				cyan.Freeze();

				// --- Plots (12 EMAs) — line width is the "1" inside Stroke(...) ---
				AddPlot(new Stroke(orange, 1), PlotStyle.Line, "EMA_P1");
				AddPlot(new Stroke(orange, 1), PlotStyle.Line, "EMA_P2");
				AddPlot(new Stroke(orange, 1), PlotStyle.Line, "EMA_P3");
				AddPlot(new Stroke(orange, 1), PlotStyle.Line, "EMA_P4");
				AddPlot(new Stroke(orange, 1), PlotStyle.Line, "EMA_P5");
				AddPlot(new Stroke(orange, 1), PlotStyle.Line, "EMA_P6");
				AddPlot(new Stroke(cyan,   1), PlotStyle.Line, "EMA_P7");
				AddPlot(new Stroke(cyan,   1), PlotStyle.Line, "EMA_P8");
				AddPlot(new Stroke(cyan,   1), PlotStyle.Line, "EMA_P9");
				AddPlot(new Stroke(cyan,   1), PlotStyle.Line, "EMA_P10");
				AddPlot(new Stroke(cyan,   1), PlotStyle.Line, "EMA_P11");
				AddPlot(new Stroke(cyan,   1), PlotStyle.Line, "EMA_P12");

				// --- Default period values (standard Guppy GMMA) ---
				P1 = 3;   P2 = 5;   P3 = 8;   P4 = 10;  P5 = 12;  P6 = 15;
				P7 = 30;  P8 = 35;  P9 = 40;  P10 = 45; P11 = 50; P12 = 60;

				// --- Default visibility (P7 and P9 OFF, everything else ON) ---
				Show_P1  = true;
				Show_P2  = true;
				Show_P3  = true;
				Show_P4  = true;
				Show_P5  = true;
				Show_P6  = true;
				Show_P7  = false;   // OFF by default
				Show_P8  = true;
				Show_P9  = false;   // OFF by default
				Show_P10 = true;
				Show_P11 = true;
				Show_P12 = true;
			}
		}

		protected override void OnBarUpdate()
		{
			// Need at least the longest period of bars before computing anything.
			// EMA(60) gives sensible values well before 60 bars, but we wait to be safe.
			if (CurrentBar < 1) return;

			// For each EMA: only compute & plot if the user has it enabled (Show_Px = true).
			// When disabled, we leave the plot unset so nothing draws on the chart.
			if (Show_P1)  Values[0][0]  = EMA(Close, P1)[0];
			if (Show_P2)  Values[1][0]  = EMA(Close, P2)[0];
			if (Show_P3)  Values[2][0]  = EMA(Close, P3)[0];
			if (Show_P4)  Values[3][0]  = EMA(Close, P4)[0];
			if (Show_P5)  Values[4][0]  = EMA(Close, P5)[0];
			if (Show_P6)  Values[5][0]  = EMA(Close, P6)[0];
			if (Show_P7)  Values[6][0]  = EMA(Close, P7)[0];
			if (Show_P8)  Values[7][0]  = EMA(Close, P8)[0];
			if (Show_P9)  Values[8][0]  = EMA(Close, P9)[0];
			if (Show_P10) Values[9][0]  = EMA(Close, P10)[0];
			if (Show_P11) Values[10][0] = EMA(Close, P11)[0];
			if (Show_P12) Values[11][0] = EMA(Close, P12)[0];
		}

		#region Properties
		// ----- Period values (P1–P12) -----
		[NinjaScriptProperty]
		[Range(1, int.MaxValue)]
		[Display(Name = "P1 period",  Order = 1,  GroupName = "Periods")]
		public int P1 { get; set; }

		[NinjaScriptProperty]
		[Range(1, int.MaxValue)]
