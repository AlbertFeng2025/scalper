        #region Control panel - WPF window with proper threading

        /// <summary>
        /// Open the panel on the WPF UI thread. Safe to call from strategy thread.
        /// </summary>
        private void OpenControlPanel()
        {
            try
            {
                Application app = Application.Current;
                if (app == null)
                {
                    Print("[PANEL] WARN: Application.Current is null. Cannot create panel.");
                    return;
                }

                app.Dispatcher.BeginInvoke(new Action(() =>
                {
                    try
                    {
                        if (panel != null) return; // already open
                        panel = new ControlPanel(this);
                        panel.Show();
                        Print("[PANEL] Control panel opened.");
                    }
                    catch (Exception ex)
                    {
                        Print(string.Format("[PANEL] Open error: {0}", ex.Message));
                    }
                }));
            }
            catch (Exception ex)
            {
                Print(string.Format("[PANEL] Dispatcher error: {0}", ex.Message));
            }
        }

        /// <summary>
        /// Close panel during strategy termination. Uses synchronous Invoke
        /// to ensure cleanup completes before strategy is finalized.
        /// </summary>
        private void CloseControlPanel()
        {
            try
            {
                Application app = Application.Current;
                if (app == null) return;

                app.Dispatcher.Invoke(new Action(() =>
                {
                    try
                    {
                        if (panel != null)
                        {
                            panel.MarkClosingFromStrategy();
                            panel.Close();
                            panel = null;
                        }
                    }
                    catch (Exception ex)
                    {
                        Print(string.Format("[PANEL] Close error: {0}", ex.Message));
                    }
                }));
            }
            catch (Exception ex)
            {
                Print(string.Format("[PANEL] Close dispatcher error: {0}", ex.Message));
            }
        }

        /// <summary>
        /// Refresh the live status block. Called every tick from OnBarUpdate.
        /// All UI work marshalled via Dispatcher.BeginInvoke.
        /// </summary>
        private void RefreshPanelStatus()
        {
            if (panel == null) return;

            try
            {
                double curPrice = GetCurrentLastPrice();
                double unrealized = (currentState == TradeState.InPosition && actualFillPrice > 0 && curPrice > 0)
                    ? curPrice - actualFillPrice
                    : 0;

                string state = currentState.ToString();
                string posDesc = string.Format("{0} qty={1}", Position.MarketPosition, Position.Quantity);
                string fillStr = (actualFillPrice > 0) ? actualFillPrice.ToString("F2") : "--";
                string stopStr = (currentStopPrice > 0) ? currentStopPrice.ToString("F2") : "--";
                string tgtStr  = (currentTargetPrice > 0) ? currentTargetPrice.ToString("F2") : "--";
                string unrlStr = (currentState == TradeState.InPosition) ? string.Format("{0:F2} pts", unrealized) : "--";
                bool canFire   = (currentState == TradeState.Idle);
                bool canClose  = (currentState == TradeState.WaitingForFill || currentState == TradeState.InPosition);

                panel.PostUpdate(state, posDesc, fillStr, stopStr, tgtStr, unrlStr, canFire, canClose);
            }
            catch
            {
                // panel may have been closed mid-update; swallow
            }
        }

        private void UpdatePanelLog(string line)
        {
            if (panel == null) return;
            try { panel.PostLogLine(line); } catch { }
        }

        /// <summary>
        /// Called by the panel when the user X's the window. Strategy keeps running
        /// but the panel reference is nulled so we don't try to update a dead window.
        /// </summary>
        internal void OnPanelClosedByUser()
        {
            panel = null;
            Print("[PANEL] User closed panel. Strategy continues without UI.");
        }

