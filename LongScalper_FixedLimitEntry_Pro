                for (int i = 0; i < 6; i++)
                    grid.RowDefinitions.Add(new RowDefinition { Height = GridLength.Auto });

                AddRow(grid, 0, "State:",      out txtState);
                AddRow(grid, 1, "Position:",   out txtPosition);
                AddRow(grid, 2, "Fill:",       out txtFill);
                AddRow(grid, 3, "Stop:",       out txtStop);
                AddRow(grid, 4, "Target:",     out txtTarget);
                AddRow(grid, 5, "Unrealized:", out txtUnrealized);

                root.Children.Add(grid);

                // Big FIRE button
                btnFire = new Button
