                    Foreground = Brushes.White,
                    Margin     = new Thickness(0, 8, 0, 6)
                };
                btnFire.Click += (s, e) =>
                {
                    owner.fireRequested = true;
                    AddLogLine("FIRE clicked");
                };
                root.Children.Add(btnFire);

                // Force close button
                btnForceClose = new Button
                {
                    Content    = "Force Close Position",
                    Height     = 36,
                    FontSize   = 13,
                    FontWeight = FontWeights.Bold,
                    Background = new SolidColorBrush(Color.FromRgb(170, 80, 0)),
                    Foreground = Brushes.White,
                    Margin     = new Thickness(0, 0, 0, 8),
                    IsEnabled  = false
                };
                btnForceClose.Click += (s, e) =>
                {
                    owner.forceCloseRequested = true;
                    AddLogLine("Force-close clicked");
                };
                root.Children.Add(btnForceClose);

                // Log
                root.Children.Add(new TextBlock
                {
                    Text = "Log",
                    FontSize = 12,
                    Foreground = Brushes.LightGray,
                    Margin = new Thickness(0, 4, 0, 2)
                });

                logItems = new ObservableCollection<string>();
                lstLog = new ListBox
                {
                    Height = 180,
                    Background = new SolidColorBrush(Color.FromRgb(10, 10, 10)),
                    Foreground = Brushes.LightGray,
                    FontFamily = new FontFamily("Consolas"),
                    FontSize = 11,
                    BorderBrush = Brushes.DimGray,
                    ItemsSource = logItems
                };
                root.Children.Add(lstLog);

                Content = root;
            }

            private static void AddRow(Grid g, int row, string label, out TextBlock value)
            {
                var lbl = new TextBlock
                {
                    Text = label,
                    Foreground = Brushes.LightGray,
                    FontSize = 13,
                    Margin = new Thickness(0, 2, 0, 2)
                };
                Grid.SetRow(lbl, row);
                Grid.SetColumn(lbl, 0);
                g.Children.Add(lbl);

                value = new TextBlock
                {
                    Text = "--",
                    Foreground = Brushes.White,
                    FontSize = 13,
                    FontWeight = FontWeights.Bold,
                    Margin = new Thickness(0, 2, 0, 2)
                };
                Grid.SetRow(value, row);
                Grid.SetColumn(value, 1);
                g.Children.Add(value);
            }

            // ---- Public API used by the strategy ----

            public void PostUpdate(string state, string position, string fill, string stop,
                                   string target, string unrealized, bool canFire, bool canClose)
            {
                if (!Dispatcher.CheckAccess())
                {
                    Dispatcher.BeginInvoke(new Action(() =>
                        PostUpdate(state, position, fill, stop, target, unrealized, canFire, canClose)));
                    return;
                }
                try
                {
                    txtState.Text      = state;
                    txtPosition.Text   = position;
                    txtFill.Text       = fill;
                    txtStop.Text       = stop;
                    txtTarget.Text     = target;
                    txtUnrealized.Text = unrealized;
                    btnFire.IsEnabled       = canFire;
                    btnForceClose.IsEnabled = canClose;

                    txtState.Foreground = (state == "InPosition") ? Brushes.LimeGreen
                                        : (state == "WaitingForFill") ? Brushes.Yellow
                                        : (state == "Done") ? Brushes.Gray
                                        : Brushes.White;
                }
                catch { }
            }

            public void PostLogLine(string line)
            {
                if (!Dispatcher.CheckAccess())
                {
                    Dispatcher.BeginInvoke(new Action(() => PostLogLine(line)));
                    return;
                }
                AddLogLine(line);
            }

            private void AddLogLine(string line)
            {
                try
                {
                    string stamped = string.Format("{0}  {1}", DateTime.Now.ToString("HH:mm:ss"), line);
                    logItems.Add(stamped);
                    while (logItems.Count > 200) logItems.RemoveAt(0);
                    lstLog.ScrollIntoView(stamped);
                }
                catch { }
            }

            public void MarkClosingFromStrategy()
            {
                closingFromStrategy = true;
            }

            private void OnClosingHandler(object sender, CancelEventArgs e)
            {
                Closing -= OnClosingHandler;
                if (!closingFromStrategy)
                {
                    // user clicked X
                    try { owner.OnPanelClosedByUser(); } catch { }
                }
            }
        }

