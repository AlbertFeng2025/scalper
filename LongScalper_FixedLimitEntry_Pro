        #region NinjaScript State Machine

        protected override void OnStateChange()
        {
            if (State == State.SetDefaults)
            {
                Description                                 = "Long-only manual/signal-driven launcher with WPF control panel. Reuses LongScalper v2.6 trading logic but waits for FIRE button (or future API call) instead of auto-firing on enable.";
                Name                                        = "LongScalper_FixedLimitEntry_Pro";
                Calculate                                   = Calculate.OnEachTick;
                EntriesPerDirection                         = 1;
                EntryHandling                               = EntryHandling.AllEntries;
                IsExitOnSessionCloseStrategy                = true;
                ExitOnSessionCloseSeconds                   = 30;
                IsFillLimitOnTouch                          = false;
                MaximumBarsLookBack                         = MaximumBarsLookBack.TwoHundredFiftySix;
                OrderFillResolution                         = OrderFillResolution.Standard;
                Slippage                                    = 0;
                StartBehavior                               = StartBehavior.WaitUntilFlat;
                TimeInForce                                 = TimeInForce.Day;
                TraceOrders                                 = false;
                RealtimeErrorHandling                       = RealtimeErrorHandling.StopCancelClose;
                StopTargetHandling                          = StopTargetHandling.PerEntryExecution;
                BarsRequiredToTrade                         = 20;
                IsInstantiatedOnEachOptimizationIteration   = true;

                // ---- Defaults ----
                Quantity                = 1;

                LimitMode               = ProEntryLimitMode.OffsetFromLastPrice;
                FixedLimitPrice         = 0;

                EntryOffsetMultiplier   = 0.10;
                BarSizeAveragePeriod    = 10;
                OrderLifeSeconds        = 5;
                ProfitTargetPoints      = 10;

                StopMode                = ProStopLossMode.OffsetFromFilledPrice;
                StopOffsetMultiplier    = 2.0;
                TrailOffsetMultiplier   = 0.8;

                HardStopPoints          = 20;
                TrailDistancePoints     = 8;

                MonitorIntervalSeconds  = 3;
                PullbackTolerancePoints = 2;
                DisableDelaySeconds     = 1.5;
                EnableSoundOnFill       = true;
                AuditLogPath            = @"C:\temp";
            }
            else if (State == State.Configure)
            {
                AddDataSeries(BarsPeriodType.Minute, 1);
            }
            else if (State == State.DataLoaded)
            {
                ResetTradeState();
            }
            else if (State == State.Realtime)
            {
                Print("================================================================");
                Print(string.Format("[INIT] LongScalper_Pro v1.0 armed at {0}", DateTime.Now.ToString("HH:mm:ss.fff")));
                Print(string.Format("[INIT] LimitMode={0}, FixedLimitPrice={1}", LimitMode, FixedLimitPrice));
                Print(string.Format("[INIT] StopMode={0}", StopMode));
                if (StopMode == ProStopLossMode.OffsetFromFilledPrice)
                    Print(string.Format("[INIT]   StopOffsetMult={0}, TrailOffsetMult={1} (x avgBarSize)",
                        StopOffsetMultiplier, TrailOffsetMultiplier));
                else
                    Print(string.Format("[INIT]   HardStop={0}pts, Trail={1}pts", HardStopPoints, TrailDistancePoints));
                Print(string.Format("[INIT] AuditLogPath: {0}", AuditLogPath));
                Print("[INIT] Waiting for FIRE button click...");

                // Open the control panel only once we're realtime - safer than DataLoaded
                // because the strategy is fully wired up by now.
                OpenControlPanel();
            }
            else if (State == State.Terminated)
            {
                Print(string.Format("[TERM] Strategy terminated at {0}", DateTime.Now.ToString("HH:mm:ss.fff")));
                try { CleanupRemainingBrackets(); } catch { }
                CloseControlPanel();
            }
        }

        #endregion

        #region OnBarUpdate - main loop

        protected override void OnBarUpdate()
        {
            if (CurrentBars[0] < BarsRequiredToTrade) return;
            if (BarsArray.Length > MinuteBarsIndex && CurrentBars[MinuteBarsIndex] < BarSizeAveragePeriod) return;
            if (State != State.Realtime) return;

            // Defensive: detect account-flat-but-strategy-thinks-otherwise
            CheckForOrphanedState();

            // Cross-thread requests from the panel ----------------------------

            if (forceCloseRequested)
            {
                forceCloseRequested = false;
                HandleForceCloseRequest();
            }

            if (fireRequested)
            {
                fireRequested = false;
                if (currentState == TradeState.Idle)
                {
                    Print("[FIRE] FIRE button clicked. Placing entry order.");
                    PlaceEntryOrder();
                }
                else
                {
                    Print(string.Format("[FIRE] Ignored - currentState is {0}, not Idle.", currentState));
                    UpdatePanelLog(string.Format("FIRE ignored - state is {0}", currentState));
                }
            }

            // Standard lifecycle ----------------------------------------------

            switch (currentState)
            {
                case TradeState.Idle:
                    // Just wait. Panel button or future API drives the entry.
                    break;

                case TradeState.WaitingForFill:
                    if ((DateTime.Now - entryOrderPlacedTime).TotalSeconds >= OrderLifeSeconds)
                    {
                        if (entryOrder != null && entryOrder.OrderState == OrderState.Working)
                        {
                            Print(string.Format("[TIMEOUT] Order life expired ({0}s). Cancelling.", OrderLifeSeconds));
                            CancelOrder(entryOrder);
                        }
                    }
                    break;

                case TradeState.InPosition:
                    if ((DateTime.Now - lastMonitorCheckTime).TotalSeconds >= MonitorIntervalSeconds)
                        DoTrailingCheck();
                    break;

                case TradeState.ClosingDelay:
                    if ((DateTime.Now - closingDelayStartTime).TotalSeconds >= DisableDelaySeconds)
                    {
                        Print("[CLOSE] Delay elapsed. Writing audit and disabling.");
                        CleanupRemainingBrackets();
                        WriteAuditLog(finalExitReason, actualFillPrice, finalExitPrice, finalPnLPoints);
                        currentState = TradeState.Done;
                        DisableStrategy();
                    }
                    break;

                case TradeState.Done:
                    break;
            }

            // Panel status refresh - cheap, do it every tick
            RefreshPanelStatus();
        }

